# ==========================================
# 1. BIẾN MÔI TRƯỜNG & BẢO MẬT (QUAN TRỌNG NHẤT)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
# (Lưu ý: Không chặn file .env.example để anh em còn clone về biết đường setup)

# ==========================================
# 2. BACKEND (PYTHON / FASTAPI / UV)
# ==========================================
# Môi trường ảo (Virtual Environments)
.venv/
venv/
env/

# Cache và file biên dịch của Python
__pycache__/
*.py[cod]
*$py.class
.Python

# Cache của các công cụ test và format code (Ruff, Pytest)
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# ==========================================
# 3. FRONTEND (NODE.JS / REACT / NEXT.JS)
# ==========================================
# Thư viện tải về
node_modules/
jspm_packages/

# Thư mục build ra sản phẩm cuối
dist/
build/
out/
.next/

# Log lỗi của NPM/Yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Cache của các nền tảng deploy (như Vercel)
.vercel/

# ==========================================
# 4. HỆ ĐIỀU HÀNH (OS)
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ==========================================
# 5. CÔNG CỤ LẬP TRÌNH (IDE / EDITORS)
# ==========================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# PyCharm / WebStorm / IntelliJ
.idea/
*.iws
*.iml
*.ipr